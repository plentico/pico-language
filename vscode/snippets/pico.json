{
  "Frontmatter": {
    "prefix": ["---", "fence"],
    "body": [
      "---",
      "$0",
      "---"
    ],
    "description": "Pico frontmatter block"
  },
  "Component Self-Closing": {
    "prefix": ["<Comp"],
    "body": [
      "<${1:Component} ${2:prop}={${3:value}} /"
    ],
    "description": "Pico self-closing component"
  },
  "Component with Children": {
    "prefix": ["<Compch"],
    "body": [
      "<${1:Component} ${2:prop}={${3:value}}>",
      "\t$0",
      "</${1:Component}"
    ],
    "description": "Pico component with children"
  },
  "Dynamic Component": {
    "prefix": ["<=\"", "<="],
    "body": [
      "<=\"${1:./component.pico}\" ${2:prop}={${3:value}} /"
    ],
    "description": "Pico dynamic component"
  },
  "Style Block": {
    "prefix": ["<style"],
    "body": [
      "<style>",
      "\t$0",
      "</style"
    ],
    "description": "Pico style block"
  },
  "Script Block": {
    "prefix": ["<script"],
    "body": [
      "<script>",
      "\t$0",
      "</script"
    ],
    "description": "Pico script block"
  }
}
